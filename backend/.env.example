# Server
PORT=4000
NODE_ENV=development

# Database — single URL, works with any Postgres
# Supabase:   postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# AWS RDS:    postgresql://[user]:[password]@[host]:5432/[dbname]
# Local:      postgresql://postgres:postgres@localhost:5432/property
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres
# Set to 'false' if your DB doesn't require SSL (e.g. local dev)
DB_SSL=true

# JWT
JWT_ACCESS_SECRET=propertyx-access-secret-haryana-2026-secure
JWT_REFRESH_SECRET=propertyx-refresh-secret-haryana-2026-secure
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MSG91 (leave blank — OTP logs to console in dev)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=PROPLX

# Dummy OTP for testing
DUMMY_PHONE=9999999999
DUMMY_OTP=123456

# AWS S3
S3_REGION=ap-south-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OTP config
OTP_RATE_LIMIT=3
OTP_EXPIRY_MINUTES=10
